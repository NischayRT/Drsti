{
  "name": "Drsti",
  "author": "Nischay Reddy Thigulla",
  "version": "1.0.0",
  "description": "AI-powered focus timer with gaze detection",
  "main": "electron/main.js",
  "scripts": {
    "dev":        "concurrently \"npm run next:dev\" \"wait-on http://localhost:3000 && electron .\"",
    "next:dev":   "cd renderer && npm run dev",
    "build":      "npm run build:next && npm run build:python",
    "build:next": "cd renderer && npm run build",
    "build:python": "cd python-api && pip install pyinstaller && pyinstaller Drsti.spec --distpath dist/Drsti-api",
    "dist":       "npm run build && electron-builder",
    "dist:win":   "npm run build && electron-builder --win",
    "dist:mac":   "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "devDependencies": {
    "concurrently":     "^8.2.2",
    "electron":         "^28.0.0",
    "electron-builder": "^24.13.3",
    "wait-on":          "^7.2.0"
  },
  "build": {
    "appId":       "com.drsti.app",
    "productName": "Drsti",
    "copyright":   "Copyright © 2025 Nischay Reddy Thigulla",
    "asar":        false,

    "directories": {
      "output":    "dist",
      "buildResources": "assets"
    },

    "files": [
      "electron/**/*",
      "renderer/out/**/*",
      "!renderer/out/**/*.map",
      "!**/node_modules/**",
      "!python-api/**"
    ],

    "extraResources": [
      {
        "from": "python-api/dist/Drsti-api.exe",
        "to":   "Drsti-api.exe"
      }
    ],

    "protocols": [
      {
        "name": "Drsti",
        "schemes": ["Drsti"]
      }
    ],

    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon":   "assets/icon.ico",
      "artifactName": "Drsti-Setup-${version}.${ext}"
    },

    "nsis": {
      "oneClick":             false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon":        "assets/icon.ico",
      "uninstallerIcon":      "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName":         "Drsti"
    },

    "mac": {
      "target":   [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon":     "assets/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "Drsti-${version}-${arch}.${ext}"
    },

    "dmg": {
      "title":  "Install Drsti",
      "icon":   "assets/icon.icns",
      "window": { "width": 540, "height": 380 }
    },

    "linux": {
      "target":   [{ "target": "AppImage", "arch": ["x64"] }],
      "icon":     "assets/icon.png",
      "category": "Utility",
      "artifactName": "Drsti-${version}.${ext}"
    },

    "publish": null
  }
}